// ============================================
// VERIFICARLO - Schema de Base de Datos
// Sistema de Agendamiento Semiautomático
// ============================================

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  CLIENT
  INSPECTOR
  ADMIN
}

enum InspectionType {
  legal
  basica
  completa
}

enum BookingStatus {
  PENDING_PAYMENT // Slot reservado, esperando pago (30 min max)
  PAID            // Pagado, asignando inspector
  CONFIRMED       // Pagado + inspector asignado
  COMPLETED       // Inspección realizada
  CANCELLED       // Cancelada por cliente/admin
  NO_SHOW         // Cliente no se presentó
  EXPIRED         // Pago no completado en 30 min
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InspectionResultStatus {
  PENDING   // Aún no evaluado
  OK        // Aprobado sin observaciones
  WARNING   // Aprobado con observaciones menores
  CRITICAL  // No aprobado - Requiere atención
}

// ============================================
// AUTENTICACIÓN (NextAuth)
// ============================================

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  phone         String?   // Para WhatsApp
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true) // Para desactivar inspectores
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ============================================
  // CAMPOS ESPECÍFICOS POR ROL
  // ============================================
  
  // Solo INSPECTOR: zona de atención y disponibilidad
  availability Json?     // {"lunes": ["09:00-13:00", "14:00-18:00"], ...}

  // Solo CLIENT: dirección para inspección a domicilio
  address      String?   // Dirección completa
  district     String?   // Distrito de Lima

  // Relaciones de autenticación
  accounts Account[]
  sessions Session[]

  // Relaciones de negocio
  vehicles         Vehicle[]
  clientBookings   Booking[]     @relation("ClientBookings")
  inspectorBookings Booking[]    @relation("InspectorBookings")
  blockedDates     BlockedDate[]
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CATÁLOGO DE PLANES DE INSPECCIÓN
// ============================================

model InspectionPlan {
  id          Int            @id @default(autoincrement())
  type        InspectionType
  title       String
  description String         @db.Text
  price       Int            // En soles (ej: 150 = S/150.00)

  items    InspectionPlanItem[]
  bookings Booking[]
}

model InspectionPlanItem {
  id               Int    @id @default(autoincrement())
  inspectionPlanId Int
  label            String

  inspectionPlan InspectionPlan @relation(fields: [inspectionPlanId], references: [id], onDelete: Cascade)

  @@index([inspectionPlanId])
}

// ============================================
// VEHÍCULOS
// ============================================

model Brand {
  id   Int    @id @default(autoincrement())
  name String @unique
  logo String

  models Model[]
}

model Model {
  id       Int    @id @default(autoincrement())
  brandId  Int
  name     String
  yearFrom Int
  yearTo   Int

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]

  @@unique([brandId, name])
  @@index([brandId])
}

// Vehículo del cliente (separado para reutilización)
model Vehicle {
  id      Int     @id @default(autoincrement())
  userId  Int
  modelId Int
  year    Int
  plate   String? // Placa opcional
  mileage Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  model    Model     @relation(fields: [modelId], references: [id])
  bookings Booking[]

  @@unique([plate]) // Única solo si tiene valor
  @@index([userId])
}

// ============================================
// RESERVAS (BOOKING)
// ============================================

model Booking {
  id Int @id @default(autoincrement())

  // Relaciones principales
  clientId         Int
  inspectorId      Int?  // Se asigna después del pago
  inspectionPlanId Int
  vehicleId        Int

  // Datos de la cita
  date      DateTime @db.Date // Solo fecha (YYYY-MM-DD)
  timeSlot  String   @db.VarChar(5) // "09:00", "09:45", etc.
  startTime DateTime // Fecha + hora completa
  endTime   DateTime // startTime + 45 min

  // Estado y control
  status    BookingStatus @default(PENDING_PAYMENT)
  expiresAt DateTime? // Para PENDING_PAYMENT (30 min)

  // Reprogramación
  isRescheduled   Boolean @default(false)
  rescheduledFrom Int? // ID del booking original

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  // Notas
  clientNotes    String? @db.Text // Notas del cliente
  inspectorNotes String? @db.Text // Notas del inspector
  adminNotes     String? @db.Text // Notas del admin

  // Relaciones
  client         User              @relation("ClientBookings", fields: [clientId], references: [id])
  inspector      User?             @relation("InspectorBookings", fields: [inspectorId], references: [id])
  inspectionPlan InspectionPlan    @relation(fields: [inspectionPlanId], references: [id])
  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id])
  payment        Payment?
  report         InspectionReport? // Informe de la inspección (solo si está COMPLETED)

  @@index([clientId])
  @@index([inspectorId])
  @@index([date, timeSlot])
  @@index([status])
  @@index([expiresAt])
  @@index([startTime])
}

// ============================================
// PAGOS
// ============================================

model Payment {
  id        Int @id @default(autoincrement())
  bookingId Int @unique

  // Datos Culqi
  culqiChargeId String? @unique
  culqiToken    String?

  // Montos
  amount   Int    // En céntimos (ej: 15000 = S/150.00) //debe de ser double o decimal
  currency String @default("PEN")

  // Estado
  status PaymentStatus @default(PENDING)

  // Datos de facturación
  receiptNumber String?
  receiptUrl    String?

  // Timestamps
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  // Metadata de Culqi
  metadata Json?

  // Error info (si falla)
  errorCode    String?
  errorMessage String? @db.Text

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([culqiChargeId])
  @@index([status])
}

// ============================================
// INFORME DE INSPECCIÓN
// ============================================

model InspectionReport {
  id        Int @id @default(autoincrement())
  bookingId Int @unique

  // ============================================
  // RESULTADOS POR CATEGORÍA
  // ============================================

  // Revisión Legal
  legalStatus       InspectionResultStatus @default(PENDING)
  legalScore        Int?                   // Puntaje 0-100
  legalObservations Json?                  // Array de observaciones detalladas
  // Estructura: [{ item: "Siniestros", status: "OK", note: "Sin registros" }, ...]

  // Revisión Mecánica
  mechanicalStatus       InspectionResultStatus @default(PENDING)
  mechanicalScore        Int?                   // Puntaje 0-100
  mechanicalObservations Json?                  // Array de observaciones
  // Estructura: [{ category: "Motor", item: "Aceite", status: "WARNING", note: "Nivel bajo" }, ...]

  // Revisión de Carrocería
  bodyStatus       InspectionResultStatus @default(PENDING)
  bodyScore        Int?                   // Puntaje 0-100
  bodyObservations Json?                  // Array de observaciones
  // Estructura: [{ area: "Puerta delantera izquierda", issue: "Rayón leve", severity: "minor" }, ...]

  // ============================================
  // DATOS ADICIONALES DEL VEHÍCULO
  // ============================================

  // Kilometraje registrado en inspección
  mileageAtInspection Int?

  // VIN/Número de chasis (verificado)
  vinNumber String? @db.VarChar(17)

  // Número de motor
  engineNumber String?

  // Color real del vehículo
  actualColor String?

  // ============================================
  // RESUMEN Y RECOMENDACIONES
  // ============================================

  // Puntaje general (promedio ponderado)
  overallScore Int? // 0-100

  // Resultado final
  overallStatus InspectionResultStatus @default(PENDING)

  // Resumen ejecutivo (texto libre)
  executiveSummary String? @db.Text

  // Recomendaciones del inspector
  recommendations String? @db.Text

  // Presupuesto estimado de reparaciones (en soles)
  estimatedRepairCost Decimal? @db.Decimal(10, 2)

  // ============================================
  // VERIFICACIÓN DE DOCUMENTOS
  // ============================================

  // Tarjeta de propiedad verificada
  ownershipCardVerified Boolean @default(false)

  // SOAT vigente
  soatValid Boolean @default(false)
  soatExpiryDate DateTime? @db.Date

  // Revisión técnica vigente
  technicalReviewValid Boolean @default(false)
  technicalReviewExpiryDate DateTime? @db.Date

  // ============================================
  // METADATA
  // ============================================

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime? // Cuando el inspector finalizó el informe

  // Firma digital del inspector (hash o URL)
  inspectorSignature String?

  // PDF generado
  pdfUrl    String?
  pdfHash   String? // Para verificar integridad

  // Relaciones
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  photos  InspectionPhoto[]

  @@index([bookingId])
  @@index([overallStatus])
}

// ============================================
// FOTOS DE INSPECCIÓN
// ============================================

model InspectionPhoto {
  id         Int @id @default(autoincrement())
  reportId   Int

  // URL de la imagen (en Cloudinary, S3, etc.)
  url        String
  thumbnailUrl String?

  // Categoría de la foto
  category   PhotoCategory

  // Descripción/etiqueta
  label      String?  // "Puerta delantera izquierda", "Motor - vista general", etc.

  // Orden de visualización
  sortOrder  Int      @default(0)

  // Metadata
  createdAt  DateTime @default(now())

  // Relación
  report InspectionReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([category])
}

enum PhotoCategory {
  EXTERIOR_FRONT      // Frente del vehículo
  EXTERIOR_BACK       // Parte trasera
  EXTERIOR_LEFT       // Lado izquierdo
  EXTERIOR_RIGHT      // Lado derecho
  INTERIOR_DASHBOARD  // Tablero/odómetro
  INTERIOR_SEATS      // Asientos
  INTERIOR_TRUNK      // Maletero
  ENGINE              // Motor
  TIRES               // Llantas
  DOCUMENTS           // Documentos (tarjeta, SOAT, etc.)
  DAMAGE              // Daños encontrados
  OTHER               // Otros
}

// ============================================
// FECHAS BLOQUEADAS
// ============================================

model BlockedDate {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  reason    String?  // "Feriado - Fiestas Patrias", "Mantenimiento", etc.
  createdBy Int
  createdAt DateTime @default(now())

  admin User @relation(fields: [createdBy], references: [id])

  @@index([date])
}
