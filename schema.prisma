datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
model User {
  id        Int      @id @default(autoincrement())
  fullName String
  email     String   @unique
  password  String?
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  agendas Agenda[]
}

enum Role {
  CLIENT
  INSPECTOR
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Inspeccion{
  id Int @id @default(autoincrement())
  name enumInspeccion

  title String
  description String
  price Int

  items InspeccionItem[]
  agendas Agenda[]
}

model InspeccionItem {
  id Int @id @default(autoincrement())
  inspeccionId Int
  label String

  inspeccion Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  @@index([inspeccionId])
}

enum enumInspeccion{
  LEGAL
  BASICA
  COMPLETA
}

model Brand{
  id Int @id @default(autoincrement())
  name String
  logo String

  models Model[]
}

model Model {
  id Int @id @default(autoincrement())
  brandId Int
  name String
  logo String
  yearFrom Int
  yearTo Int

  agendas Agenda[]

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  @@index([brandId])
}

model Agenda{
  id Int @id @default(autoincrement())
  userId Int
  modelId Int
  inspeccionId Int

  year Int
  mileage Int
  placa String
  fechaHora DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)
  inspeccion Inspeccion @relation(fields: [inspeccionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([modelId])
  @@index([inspeccionId])
  @@index([fechaHora])
}